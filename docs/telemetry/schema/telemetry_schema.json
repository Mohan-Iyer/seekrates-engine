        "Added subscriptions table",
        "Added consensus_results table",
        "Added sage_waitlist table"
      ]
    },
    {
      "version": "1.1.0",
      "date": "2025-10-14",
      "author": "Claude",
      "changes": [
        "Added GPS traceability to events and errors",
        "Added indexes for performance"
      ]
    },
    {
      "version": "1.0.0",
      "date": "2025-10-01",
      "author": "Claude",
      "changes": [
        "Initial schema: events, metrics, errors, sessions"
      ]
    }
  ]
}